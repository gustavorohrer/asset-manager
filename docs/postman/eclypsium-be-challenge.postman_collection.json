        }
      ]
    },
    {
      "name": "Assets - Get Details",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/assets/{{assetId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
