{
  "info": {
    "_postman_id": "6e8d2efe-a8f7-4c85-b52f-6b82d1e84cf4",
    "name": "Eclypsium BE Challenge API",
    "description": "Collection for quick reviewer validation of deployed API contracts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"response includes status=up\", function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.status).to.eql(\"up\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Assets - Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/assets/summary",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "assets",
            "summary"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"summary includes total counters\", function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property(\"total\");",
              "  pm.expect(body).to.have.property(\"withVulnerabilities\");",
              "  pm.expect(body).to.have.property(\"withThreats\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Assets - List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/assets?page=1&pageSize=3&sortBy=createdAt&sortOrder=desc",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "assets"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "pageSize",
              "value": "3"
            },
            {
              "key": "sortBy",
              "value": "createdAt"
            },
            {
              "key": "sortOrder",
              "value": "desc"
            },
            {
              "key": "has_vulnerabilities",
              "value": "true",
              "description": "Optional: filter assets with vulnerabilities detected in latest component scans.",
              "disabled": true
            },
            {
              "key": "has_threats",
              "value": "true",
              "description": "Optional: filter assets with threats detected in latest component scans.",
              "disabled": true
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"envelope includes data and pagination\", function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property(\"data\");",
              "  pm.expect(body).to.have.property(\"pagination\");",
              "  pm.expect(body.data).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Assets - Invalid Query (page=0)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/assets?page=0",
